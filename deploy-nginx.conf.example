server {
    listen 80;
    server_name gridfinity.filipkin.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    server_name gridfinity.filipkin.com;

    ssl_certificate /etc/letsencrypt/live/gridfinity.filipkin.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/gridfinity.filipkin.com/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    # STL uploads can be large; default nginx limit is 1MB.
    client_max_body_size 110M;

    location / {
        proxy_pass http://127.0.0.1:8090;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Render endpoint can take minutes for large bins.
        proxy_read_timeout 600s;
        proxy_send_timeout 600s;
        proxy_buffering off;
    }
}
